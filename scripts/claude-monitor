#!/usr/bin/env bash
#
# claude-monitor -- start / stop / status wrapper for Claude Code Usage Monitor
#
set -euo pipefail

# ---------------------------------------------------------------------------
# Resolve the project root (one level up from this script's directory)
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
VENV_PYTHON="$PROJECT_DIR/.venv/bin/python"
PID_FILE="$PROJECT_DIR/.claude-monitor.pid"
LOG_FILE="$PROJECT_DIR/claude-monitor.log"

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
_find_pid() {
    # First check the PID file
    if [[ -f "$PID_FILE" ]]; then
        local pid
        pid=$(<"$PID_FILE")
        if kill -0 "$pid" 2>/dev/null; then
            echo "$pid"
            return 0
        fi
        # Stale PID file -- remove it
        rm -f "$PID_FILE"
    fi

    # Fall back to pgrep
    pgrep -f "python -m src.main" 2>/dev/null | head -1 || true
}

_require_venv() {
    if [[ ! -x "$VENV_PYTHON" ]]; then
        echo "Error: Virtual environment not found at $VENV_PYTHON"
        echo "Create one first:  python3 -m venv $PROJECT_DIR/.venv && $VENV_PYTHON -m pip install -r $PROJECT_DIR/requirements.txt"
        exit 1
    fi
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_start() {
    _require_venv

    local existing_pid
    existing_pid=$(_find_pid)
    if [[ -n "$existing_pid" ]]; then
        echo "Claude Usage Monitor is already running (PID $existing_pid)."
        exit 0
    fi

    echo "Starting Claude Usage Monitor..."
    cd "$PROJECT_DIR"
    nohup "$VENV_PYTHON" -m src.main >> "$LOG_FILE" 2>&1 &
    local pid=$!
    echo "$pid" > "$PID_FILE"
    echo "Started (PID $pid). Logs: $LOG_FILE"
}

cmd_stop() {
    local pid
    pid=$(_find_pid)
    if [[ -z "$pid" ]]; then
        echo "Claude Usage Monitor is not running."
        exit 0
    fi

    echo "Stopping Claude Usage Monitor (PID $pid)..."
    kill "$pid" 2>/dev/null || true
    rm -f "$PID_FILE"
    echo "Stopped."
}

cmd_status() {
    local pid
    pid=$(_find_pid)
    if [[ -n "$pid" ]]; then
        echo "Claude Usage Monitor is running (PID $pid)."
    else
        echo "Claude Usage Monitor is not running."
    fi
}

# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
case "${1:-}" in
    start)  cmd_start  ;;
    stop)   cmd_stop   ;;
    status) cmd_status ;;
    *)
        echo "Usage: claude-monitor {start|stop|status}"
        exit 1
        ;;
esac
